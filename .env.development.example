NODE_ENV=development
PORT=3000
API_TOKEN=dev-api-token-example
SERVE_UI=true
ALLOWED_ORIGINS=http://localhost:3000

# Frontend API exposure control
# Keep this false in local dev unless you have a reverse proxy injecting X-Gateherald-Proxy-Secret.
FRONTEND_ONLY_API=false
ADMIN_PROXY_SHARED_SECRET=

# Optional admin API token for direct API clients/tools.
# Leave blank for local frontend access without a proxy adding auth headers.
ADMIN_API_TOKEN=

# Built-in frontend login/logout flow is optional in local development.
FRONTEND_AUTH_ENABLED=false
# FRONTEND_AUTH_USERNAME=gateadmin
# FRONTEND_AUTH_PASSWORD=change_me
# FRONTEND_AUTH_SESSION_SECRET=replace_with_a_long_random_secret
FRONTEND_AUTH_SESSION_TTL_MINUTES=480

# Set true only while debugging payload transforms locally.
DEBUG_TRANSFORMED_PAYLOAD=false
